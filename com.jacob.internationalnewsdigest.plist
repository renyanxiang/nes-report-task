<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jacob.internationalnewsdigest</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/Jacob/international_news_digest/run_news_digest.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/Jacob/international_news_digest</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/Jacob/international_news_digest/logs/launchd.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/Jacob/international_news_digest/logs/launchd.stderr.log</string>
</dict>
</plist>
